<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="notes-week-02">
  <title>Marshall University Calculus-based Introductory Physics Formula Sheet for Common Final Exam</title>

  <subsection>
    <title>PHY 211</title>

  <ul>
    <li><p><md>
\vec v(t) = \frac{\mathrm{d} \vec r(t)}{\mathrm{d}t}
</md></p></li>
<li><p><md>
\vec v(t) = 
\frac{\mathrm{d} x(t)}{\mathrm{d}t}\hat i
+ \frac{\mathrm{d} y(t)}{\mathrm{d}t} \hat j
+ \frac{\mathrm{d} z(t)}{\mathrm{d}t} \hat k
</md></p></li>
<li><p><md>
\vec a(t) = \frac{\mathrm{d}\vec v(t)}{\mathrm{d}t}
   = \frac{\mathrm{d}^2 \vec r(t)}{\mathrm{d} t^2}
</md></p></li>
<li><p><md>
x(t) = x_0+\int_0^t v(t) \mathrm{d} t
</md></p></li>
<li><p><md>
v(t) = v_0+\int_0^t a(t) \mathrm{d} t
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \amp x_\mathrm{f} = x_\mathrm{i} + v_\mathrm{i} t + \tfrac{1}{2} a t^2 </mrow>
      <mrow> \amp v_\mathrm{f} =  v_\mathrm{i} + a t</mrow>
      <mrow> \amp v_\mathrm{f}^2 =  v_\mathrm{i}^2 + 2 a (x_\mathrm{f} - x_\mathrm{i}) </mrow>
      <mrow> \amp v_\mathrm{avg} =  \tfrac{1}{2} (v_\mathrm{f} + v_\mathrm{i}) =\frac{\Delta x}{\Delta t}</mrow>
    </md>
  </p>
</li>
<li><p><md>
\vec{F}_\mathrm{net} = \sum {\vec{F}_i}
 = m \vec{a}
</md></p></li>
<li><p><md>
\vec{ F}_g = m \vec{g}
</md></p></li>
<li><p><md>
\lvert \vec{F}_\mathrm{s} \rvert \leq \mu_\mathrm{s} \lvert \vec{N} \rvert
</md></p></li>
<li><p><md>
\lvert \vec{F}_\mathrm{k} \rvert  = \mu_\mathrm{k} \lvert \vec{N} \rvert
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{spr} = - k \vec{\Delta L}
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{P} = \vec{F}_\mathrm{N} = P \vec{A}
</md></p></li>
<li><p><md>
 Y = \frac{\Delta P}{\Delta L / L_0}
</md></p></li>
<li><p><md>
 S = \frac{\Delta P}{\Delta x / h}
</md></p></li>
<li><p><md>
\vec{v_t} = \vec{r} \times \vec{\omega}
</md></p></li>
<li><p><md>
a_\mathrm{c} =
\frac{v_\mathrm{t}^2}{r}
= r \omega^2 = v_t \omega
</md></p></li>
<li><p><md>
\vec{a} = \vec{a_\mathrm{c}} +\vec{a_t}
</md></p></li>
<li><p><md>
\vec{F}_G = - G \frac{m_1 m_2}{r^2} \hat{r}
</md></p></li>
<li><p><md>
g = G \frac{m_\mathrm{earth}}{r^2_\mathrm{earth}}
</md></p></li>
<li><p><md>
W = \vec{F}\cdot\vec{d} 
= F d\cos (\theta)
</md></p></li>
<li><p><md>
  W = \int_{x_\mathrm{i}}^{x_\mathrm{f}} F_x \mathrm{d} x
</md></p></li>
<li><p><md>
  W = \int_{P_\mathrm{i}}^{P_\mathrm{f}} 
    \vec{F} \cdot \mathrm{d} \vec{\ell}
</md></p></li>
<li><p><md>
P_{av}=\frac{\Delta W}{\Delta t}
</md></p></li>
<li><p><md>
P=\frac{d W}{d t}
</md></p></li>
<li><p><md>
\mathrm{KE} = K= \tfrac{1}{2} m v^2
</md></p></li>
<li><p><md>
W_\mathrm{net} = \Delta K
</md></p></li>
<li><p><md>
W_\mathrm{cons} = -\Delta U = -\Delta \mathrm{PE}
</md></p></li>
<li><p><md>
K_1  + U_{1} = K_2  + U_{2}
</md></p></li>
<li><p><md>
\mathrm{PE}_G = U_G = - G \frac{m_1 m_2}{r}
</md></p></li>
<li><p><md>
U_G = m g h
</md></p></li>
<li><p><md>
\mathrm{PE}_\mathrm{S} = U_\mathrm{S} = \tfrac{1}{2} k x^2
</md></p></li>
<li><p><md>
 F_x (x)  = -\frac{\mathrm{d} U(x)}{\mathrm{d} x}
</md></p></li>
<li><p><md>
 F_x (x)  = - k x
</md></p></li>
<li><p><md>
\vec{r}_\mathrm{cm} = \frac{\sum_i m_i \vec{r}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{v}_\mathrm{cm} = \frac{\sum_i m_i \vec{v}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{a}_\mathrm{cm}= \frac{\sum_i m_i \vec{a}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{p} = m \vec{v}
</md></p></li>
<li><p><md>
\vec{F} = \frac{\mathrm{d} \vec{p}}{\mathrm{d} t}
</md></p></li>
<li><p><md>
\vec{p}_{1,\mathrm{f}} + \vec{p}_{2,\mathrm{f}} = 
\vec{p}_{1,\mathrm{i}} + \vec{p}_{2,\mathrm{i}}\
</md></p></li>
<li><p><md>
\sum_i \vec{p}_i + \sum_i \vec F_\mathrm{ext} \Delta t = 
\sum_i \vec{p}_f 
</md></p></li>
<li><p><md>
\vec{\mathcal{J}} = \vec{F} \Delta t = \Delta \vec{p} 
</md></p></li>
<li><p><md>
  \theta =\frac{s}{r}
</md></p></li>
<li><p><md>
 \omega = \frac{d \theta}{d t} = \frac{v_\mathrm{t}}{r} 
</md></p></li>
<li><p><md>
 \alpha = \frac{d \omega}{d t} = \frac{a_\mathrm{t}}{r} 
</md></p></li>
<li><p><md>
\vec{\tau} = \vec{r} \times \vec{F} = I \vec{\alpha}
</md></p></li>
<li><p><md>
\tau = r_\perp F~,~
r_\perp = r \sin (\theta) 
</md></p></li>
<li><p><md>
\vec{L} = \vec{r} \times \vec{p} = I \vec{\omega}
</md></p></li>
<li><p><md>
L = r m v \sin( \theta)
</md></p></li>
<li><p><md>
\sum_i \vec \tau_i = \frac{d\vec L}{dt}
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \amp \theta_\mathrm{f} = \theta_\mathrm{i} + \omega_\mathrm{i} t + \tfrac{1}{2} \alpha t^2 </mrow>
      <mrow> \amp \omega_\mathrm{f} =  \omega_\mathrm{i} + \alpha t</mrow>
      <mrow> \amp \omega_\mathrm{f}^2 =  \omega_\mathrm{i}^2 + \alpha (\theta_\mathrm{f} - \theta_\mathrm{i})</mrow>
      <mrow> \amp \omega_\mathrm{avg} =  \tfrac{1}{2} (\omega_\mathrm{f} + \omega_\mathrm{i})</mrow>
    </md>
  </p>
</li>
<li><p><md>
K_\mathrm{rot} = \tfrac{1}{2} I \omega^2
</md></p></li>
<li><p><md>
W = \tau \Delta \theta 
</md></p></li>
<li><p><md>
 \omega = 2 \pi f = \frac{2 \pi}{T}
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{k}{m} }
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{g}{\ell} }
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{m g \ell_\mathrm{CM}}{I} }
</md></p></li>
<li><p><md>
 x(t) = x_0 \sin (\omega t) 
</md></p></li>
<li><p><md>
 v(t) = -x_0  \omega \cos (\omega t)
</md></p></li>
<li><p><md>
 a(t) = - x_0 \omega^2 \sin (\omega t)
</md></p></li>
<li><p><md>
 v = f \lambda 
</md></p></li>
<li><p><md>
  v = \sqrt{ \frac{F}{\mu} }
  ~;~
\mu =\frac{m}{\ell}
</md></p></li>
<li><p><md>
  k = \frac{2 \pi}{\lambda}
</md></p></li>
<li><p><md>
y(x,t) = A \sin (k x) \sin(\omega t)  
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \amp f_\mathrm{string} = f_\mathrm{open-open} = n \left( \frac{v}{2 \ell} \right) </mrow>
      <mrow> \amp \hspace{0.3cm} \textnormal{where } n \in \{  1,  2, 3, \ldots \} </mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \amp f_\mathrm{open-closed}   = n \left( \frac{v}{4 \ell} \right)</mrow>
      <mrow> \amp \hspace{0.3cm} textnormal{where } n \in \{  1,  3, 5, \ldots \} </mrow>
    </md>
  </p>
</li>
<li><p><md>
 y_\mathrm{tw} (x,t) = A \sin (k x \mp \omega t)
</md></p></li>
<li><p><md>
 f_\mathrm{o} = f_\mathrm{s} 
   \left( \frac{v \pm v_\mathrm{o}}{v \mp v_\mathrm{s}} \right) 
</md></p></li>
<li><p><md>
 f_\mathrm{beat} = \lvert f_2 - f_1 \rvert 
</md></p></li>
<li><p><md>
I = \frac{P}{A}
= \frac{P}{4 \pi r^2}
</md></p></li>
<li><p><md>
  I_0 \equiv 1.0 \times 10^{-12} \frac{\mathrm{W}}{\mathrm{m}^2}
</md></p></li>
<li><p><md>
  \beta [\mathrm{dB}] = 10 \log_{10} \left( \frac{I}{I_0} \right)
</md></p></li>
<li><p><md>
 P = \frac{F}{A}
</md></p></li>
<li><p><md>
  \rho = \frac{m}{V}
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{b} =- \rho V  \vec{g}
</md></p></li>
<li><p><md>
 P = P_0 + \rho g h 
</md></p></li>
<li><p><md>
 P_1 + \tfrac{1}{2} \rho v_1^2 + \rho g y_1 = 
  P_2  + \tfrac{1}{2} \rho v_2^2+ \rho g y_2
</md></p></li>
<li><p><md>
Q = \Phi_v \equiv \vec{v}\cdot \vec{A}  = v  A \cos (\theta)
</md></p></li>
<li><p><md>
Q = \frac{\Delta V}{\Delta t}
</md></p></li>
<li><p><md>
  A_1 v_1 = A_2 v_2
</md></p></li>
<li><p><md>
 \rho v A  = \frac{\Delta m}{\Delta t}
</md></p></li>
<li><p><md>
 \Delta L = \alpha L_0 \Delta T
</md></p></li>
<li><p><md>
 \Delta V = \beta V_0 \Delta T
</md></p></li>
  </ul>
    
  </subsection>

  <subsection xml:id="subsec-page-2-calc">
    <title>Page 2</title>

    <ul>
      <li><p><md>
 \textrm{circumference of a circle  } C =  2 \pi r
</md></p></li>
<li><p><md>
 \textrm{area of a circle  } A =  \pi r^2
</md></p></li>
<li><p><md>
 \textrm{surface area of a sphere  } A =  4 \pi r^2
</md></p></li>
<li><p><md>
 \textrm{volume of a sphere  } V =  \frac{4}{3} \pi r^3
</md></p></li>
<li><p><md>
\textrm{If } A x^2 + B x + C = 0 \textrm{,  } 
x = \frac{{-B \pm \sqrt{B^2 - 4 A C }}}{2 A}
</md></p></li>
<li><p><md>
 \log_a (xy) =  \log_a (x) +  \log_a (y)
</md></p></li>
<li><p><md>
 \log_a \left(\frac{x}{y}\right) =  \log_a (x) -  \log_a (y)
</md></p></li>
<li><p><md>
 \log_a \left(x^y\right) =  y\log_a (x)
</md></p></li>
<li><p><md>
\mathrm{If \;}  a^x = y
\mathrm{, \;}
 x = \log_a y = \frac{\log_{10} y}{\log_{10} a}
 = \frac{\ln y}{\ln a}
</md></p></li>
<li><p><md>
\mathrm{If \;} \lvert \theta \rvert &lt; 0.5 
\mathrm{\; radians, \;}
 \sin (\theta) \approx \theta
 \mathrm{\; (in \; radians) \;}
</md></p></li>
<li><p><md>
\mathrm{If \;} \lvert \theta \rvert &lt; 0.5 
\mathrm{\; radians, \;}
 \tan (\theta) \approx \theta
 \mathrm{\; (in \; radians) \;}
</md></p></li>
<li><p><md>
 \sin (-\theta) = - \sin (\theta)
</md></p></li>
<li><p><md>
 \cos (-\theta) =  \cos (\theta)
</md></p></li>
<li><p><md>
\sin(\theta_A + \theta_B) = \sin(\theta_A) \cos(\theta_B) + \cos(\theta_A) \sin(\theta_B)
</md></p></li>
<li><p><md>
\cos(\theta_A + \theta_B) = \cos(\theta_A) \cos(\theta_B) - \sin(\theta_A) \sin(\theta_B)
</md></p></li>
<li><p><md>
\sin(\theta_A) \sin(\theta_B) = 
\frac{\cos(\theta_A - \theta_B) - 
 \cos(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
\cos(\theta_A) \cos(\theta_B) = 
\frac{\cos(\theta_A - \theta_B) + 
 \cos(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
\sin(\theta_A) \cos(\theta_B) = 
\frac{\sin(\theta_A - \theta_B) + 
 \sin(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
 \textnormal{Law of Cosines}  \hspace{0.5cm}
 c^2 = a^2 + b^2 - 2 a b \cos (C)
</md></p></li>
<li><p><md>
 \textnormal{Law of Sines}  \hspace{0.5cm}
 \frac{a}{\sin (A)} =  \frac{b}{\sin (B)} =  \frac{c}{\sin (C)} 
</md></p></li>
<li><p><md>
  \left.
  \begin{array}{rcl}
  x \amp = \amp r \cos (\theta) \\
  y \amp = \amp r \sin (\theta)
  \end{array}
  \right\}
  \Longleftrightarrow
  \left\{
  \begin{array}{rcl}
  r \amp = \amp \sqrt{x^2 + y^2} \\
  \theta \amp = \amp \tan^{-1} \left( y/x \right)
  + \left\{
  \begin{array}{l}
      0^{\circ} \mathrm{, \; if \; } x &gt; 0 \\
      180^{\circ} \mathrm{, \; otherwise }
   \end{array}
   \right .
  \end{array}
  \right.
</md></p></li>
<li><p><md>
\mathrm{If \; } \vec{R} =  \vec {A} + \vec{B} , \;
R_x =  A_x + B_x \; \mathrm{and} \; 
R_y =  A_y + B_y
</md></p></li>
<li><p><md>
\mathrm{If \; } \vec{R} =  \vec {A} - \vec{B} , \;
R_x =  A_x - B_x \; \mathrm{and} \; 
R_y =  A_y - B_y
</md></p></li>
<li><p><md>
 \vec{A}\cdot\vec{B} =  \vec{B}\cdot\vec{A}  =  A_x  B_x + A_y B_y + A_z B_z  =  \lvert \vec{A} \rvert \lvert \vec{B} \rvert \cos(\theta)
</md></p></li>
<li><p><md>
 \lvert \vec{A} \times \vec{B} \rvert = \lvert \vec{A} \rvert \lvert \vec{B} \rvert \lvert \sin(\theta) \rvert
</md></p></li>
<li><p><md>
\textnormal{Newton's constant}  \hspace{0.5cm}
G = 6.67430 \! \times \!  10^{-11} \; 
\frac{\mathrm{m}^3}{\mathrm{kg}\cdot \mathrm{s}^2} 
</md></p></li>
<li><p><md>
\textrm{speed of light  }  
 c = 2.99792458 \times 10^8 \textnormal{ m/s}
</md></p></li>
<li><p><md>
\textnormal{elementary charge  }  
 e = 1.602176634 \!\times\! 10^{-19} \textnormal{ C}
</md></p></li>
<li><p><md>
\mathrm{electrostatic \; constant \;}
k = 8.987551792 \!\times\! 10^9 
\frac{\mathrm{\; N}\cdot \mathrm{m}^2}{\mathrm{C}^2} 
</md></p></li>
<li><p><md>
\mathrm{vacuum}\; \mathrm{permittivity \; }
 \epsilon_0 = 8.854187813 \!\times\! 10^{-12} \mathrm{\; F/m}
</md></p></li>
<li><p><md>
\mathrm{vacuum}\; \mathrm{permeability \; }
 \mu_0  = 
 4 \pi \!\times\! 10^{-7} 
 \mathrm{\; N} \cdot \mathrm{A}^{-2} 
 </md></p></li>
 <li><p><md>
\textnormal{Planck's constant} \;
 h = 6.62607015 \!\times\! 10^{-34}  
 \mathrm{\; J} \cdot \mathrm{s}
</md></p></li> 
<li><p><md>
\hbar \equiv \frac{h}{2 \pi} = 1.054571817 \!\times\! 10^{-34}  
 \mathrm{\; J} \cdot \mathrm{s}
</md></p></li>
<li><p><md>
\textnormal{standard gravity} \hspace{0.5 cm}
g = +9.80665 \; \frac{\mathrm{m}}{\mathrm{s}^2}
</md></p></li>
<li><p><md>
\textnormal{mass of  earth} \hspace{0.5 cm} m_\mathrm{earth} = 5.9723 \!\times\! 10^{24} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of moon} \hspace{0.5 cm} m_\mathrm{moon} = 7.346 \!\times\! 10^{22} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of sun} \hspace{0.5 cm} m_\mathrm{sun} = 1.9885 \!\times\! 10^{30} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of electron} \hspace{0.3 cm} m_\mathrm{e} = 9.1093837015 \!\times\! 10^{-31} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of proton} \hspace{0.3 cm} m_\mathrm{p} = 
1.67262192369 \!\times\! 10^{-27} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of neutron} \hspace{0.3 cm} m_\mathrm{n} = 1.67492749804  \!\times\! 10^{-27} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{volumetric radius of earth} \hspace{0.3 cm} r_\mathrm{earth} = 
6.371 \!\times\! 10^{6} \; \mathrm{m}
</md></p></li>
<li><p><md>
\textnormal{earth-moon distance} \hspace{0.3 cm} r_\mathrm{EM} = 
3.844 \!\times\! 10^{8} \; \mathrm{m}
</md></p></li>
<li><p><md>
\textnormal{earth-sun distance} \hspace{0.3 cm} r_\mathrm{ES} = 
1.496 \!\times\! 10^{11} \; \mathrm{m}
</md></p></li>
Density of air at sea level at 15$^\circ$ C:
<li><p><md>
\rho_0 = 1.225 \frac{\mathrm{kg}}{\mathrm{m}^3}
</md></p></li>
Earth's total magnetic field strength at Huntington, WV:
<li><p><md>
\lvert \vec{B}_\mathrm{earth} \rvert \approx
5.15 \!\times\! 10^{-5} \; \mathrm{T}
</md></p></li>
Vertical component of Earth's magnetic field strength at Huntington, WV:
<li><p><md>
B_{\mathrm{earth},z} \approx
4.70 \!\times\! 10^{-5} \; \mathrm{T}
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \textnormal{Bohr radius} \hspace{0.5cm} a_B \amp \equiv \frac{\hbar^2}{m_\mathrm{e} k e^2}</mrow>
      <mrow> \amp = 5.29177210903 \!\times\! 10^{-11} \; \mathrm{m}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \textnormal{Rydberg constant} \hspace{0.3cm} \amp \mathcal{R}  \equiv \frac{\hbar}{4 \pi m_\mathrm{e} a_B^2 c}</mrow>
      <mrow> \amp = 1.0973731568160  \times 10^7 \; \mathrm{m}^{-1}</mrow>
    </md>
  </p>
</li>
<li><p><md>
\textnormal{hydrogen binding energy} \hspace{0.3cm} 
E_0 %= h c \mathcal{R} 
= 13.605693123 \; \mathrm{eV}
</md></p></li>
<li><p><md>
\textnormal{scale for nuclear radius} 
\hspace{0.3cm} 
 r_\mathrm{nuc} = 1.2 \!\times\! 10^{-15} \; \mathrm{m}
</md></p></li>
    </ul>
    
  </subsection>

  <subsection xml:id="subsec-Page-3-calc">
    <title>Page 3</title>
    
    <ul>
      <li><p><md>
1 \; \mathrm{newton \;  [N]} \equiv 1 \;
\frac{\mathrm{kilogram} \cdot \mathrm{meter}}{ \mathrm{second}^2}
</md></p></li>
<li><p><md>
1 \; \mathrm{joule \; [J]} \equiv 1 \; \mathrm{newton} \cdot \mathrm{meter}
</md></p></li>
<li><p><md>
1 \; \mathrm{watt \; [W]} = 
1 \; \frac{\mathrm{joule}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{radian} \equiv \frac{180^\circ}{\pi} 
\approx 57.29577951^\circ
</md></p></li>
<li>
  <p>
    <md>
      <mrow>1 \; \frac{\mathrm{radian}}{\mathrm{second}} \amp \equiv \frac{60}{2 \pi} \; \mathrm{rpm}</mrow>
      <mrow> \amp \approx 9.549296586 \; \mathrm{rpm}</mrow>
    </md>
  </p>
</li>
<li><p><md>
1 \; \mathrm{hertz \; [Hz]} \equiv 1 \; \mathrm{second}^{-1}
</md></p></li>
<li><p><md>
1 \; \mathrm{pascal \; [Pa]} \equiv 1 \; 
\frac{\mathrm{newton}}{\mathrm{meter}^2}
</md></p></li>
<li><p><md>
1 \; \mathrm{volt \; [V]} \equiv 
1 \; \frac{\mathrm{joule}}{\mathrm{coulomb}}
</md></p></li>
<li><p><md>
1 \; \mathrm{electron-volt \; [eV]} = 
1.602176565 \!\times\! 10^{-19} \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \mathrm{farad \; [F]} \equiv 
1 \; \frac{\mathrm{coulomb}}{\mathrm{volt}}
</md></p></li>
<li><p><md>
1 \; \mathrm{ampere \; [A]} \equiv
1 \; \frac{\mathrm{coulomb}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{ohm} \; [\Omega] \equiv
1 \; \frac{\mathrm{volt}}{\mathrm{ampere}}
</md></p></li>
<li><p><md>
1 \; \mathrm{tesla} \equiv 
1 \; \frac{\mathrm{newton}}{\mathrm{ampere}\cdot
\mathrm{meter}}
</md></p></li>
<li><p><md>
1 \; \mathrm{gauss \; [G]} \equiv 10^{-4} \; \mathrm{tesla}
</md></p></li>
<li><p><md>
1 \; \mathrm{henry \; [H]} \equiv 
1 \; \mathrm{ohm} \cdot \mathrm{second}
</md></p></li>
<li><p><md>
1 \; \mathrm{diopter \; [D]} \equiv 1 \; \mathrm{meter}^{-1}
</md></p></li>
<li><p><md>
1 \; \mathrm{dalton \; [u]} = 
1.66053873 \!\times\! 10^{-27} \; \mathrm{kilogram}
</md></p></li>
<li><p><md>
1 \; \mathrm{becquerel \; [Bq]} \equiv 
1 \frac{\mathrm{decay}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{curie \; [Ci]} \equiv
3.7 \! \times \! 10^{10} \; \mathrm{becquerel}
</md></p></li>
<li><p><md>
 1 \; \mathrm{rad} \equiv 
 0.01 \; \frac{\mathrm{joule}}{\mathrm{kilogram}}
</md></p></li>
<li><p><md>
1 \; \mathrm{gray} \equiv 
 1 \; \frac{\mathrm{joule}}{\mathrm{kilogram}}
 = 100 \; \mathrm{rad}
</md></p></li>
<li><p><md>
1 \; \mathrm{rem} \equiv   
1 \; \mathrm{rad} \cdot RBE
</md></p></li>
<li><p><md>
1 \; \mathrm{sievert \; [Sv]} \equiv   
1 \; \mathrm{gray} \cdot RBE = 
100 \; \mathrm{rem}
</md></p></li>
<li><p><md>
1 \; \mathrm{inch \; [in]} \equiv   
0.0254 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{foot \; [ft]} =   
0.3048 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{mile \; [mi]} = 
1609.344 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{light \; year \; [ly]} = 
9.4605284 \!\times\! 10^{15} \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{ounce mass \; [oz]} =   
0.02835 \; \mathrm{kilogram} 
</md></p></li>
<li><p><md>
1 \; \mathrm{pound mass \; [lb]} =
0.4536 \; \mathrm{kilogram} 
</md></p></li>
<li><p><md>
1 \; \mathrm{mile \; per \; hour \; [mph]} =
0.44704 \; \frac{\mathrm{meter}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{foot \; pound \; [ft \! \cdot \! lb]} =
1.3558179 \; \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \textnormal{centipoise [cP]}  \equiv 0.1 \;
\textnormal{pascal} \cdot \textnormal{second}
</md></p></li>
<li><p><md>
1 \; \mathrm{kiloton \; [kt]} =
4.184 \!\times\! 10^{12} \; \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \mathrm{horsepower \; [hp]} =
745.69987 \; \mathrm{watt}
</md></p></li>
<li><p><md>
1 \; \mathrm{atmosphere \; [atm]} = 
1.0132501 \!\times\! 10^{5} \; \mathrm{pascal}
</md></p></li>
<li><p><md>
1 \; \mathrm{mm \; of \; mercury \; [mmHg]} =
133.32239 \; \mathrm{pascal}
</md></p></li>
<li><p><md>
1 \; \mathrm{pound \; per \; square \; inch \; [psi]} =
6894.75728 \; \mathrm{pascal}
</md></p></li>
    </ul>

  </subsection>

  <subsection xml:id="subsec-Prefixes">
    <title>Prefixes</title>

    <ul>
      <li><p><md>
\textnormal{giga [G]: }10^{9}
</md></p></li>
<li><p><md>
\textnormal{mega [M]: } 10^{6}
</md></p></li>
<li><p><md>
\textnormal{kilo [k]: } 10^{3}
</md></p></li>
<li><p><md>
\textnormal{centi [c]: } 10^{-2}
</md></p></li>
