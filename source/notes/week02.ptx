  <subsection xml:id="subsec-Moments">
    <title>Moments of Inertia</title>
    
  </subsection>

  <ul>
    <li><p><md>
\textnormal{hoop about axis} \hspace{0.3cm} I = m r^2
</md></p></li>
<li><p><md>
\textnormal{point particle about axis at distance } r \hspace{0.3cm}  I = m r^2 \\
</md></p></li>
<li><p><md>
\textnormal{ring about axis} \hspace{0.3cm} I =  \frac{1}{2} m 
\left( r_1^2 + r_2^2 \right) 
</md></p></li>
<li><p><md>
\textnormal{solid disk about axis} \hspace{0.3cm} I =  \frac{1}{2} m r^2
</md></p></li>
<li><p><md>
\textnormal{solid disk about diameter} \hspace{0.3cm}  
I =  \frac{1}{4} m r^2 + \frac{1}{12} m \ell^2
</md></p></li>
<li><p><md>
\textnormal{thin rod, axis through center}
\perp \textnormal{to length} \hspace{0.3cm}  
I =  \frac{1}{12} m \ell^2 
</md></p></li>
<li><p><md>
\textnormal{thin rod, axis through end}
\perp \textnormal{to length} \hspace{0.3cm}  
I =  \frac{1}{3} m \ell^2 
</md></p></li>
<li><p><md>
\textnormal{solid sphere about diameter}
\hspace{0.3cm}  
I =  \frac{2}{5} m r^2 
</md></p></li>
<li><p><md>
\textnormal{thin spherical shell about diameter}
\hspace{0.3cm} 
I =  \frac{2}{3} m r^2 
</md></p></li>
<li><p><md>
\textnormal{hoop about any diameter}
\hspace{0.3cm}  
I =  \frac{1}{2} m r^2 
</md></p></li>
<li><p><md>
\textnormal{slab about} \perp 
\textnormal{axis through center}
\hspace{0.3cm}  
I =  \frac{1}{2} m \left( \ell_x^2 + \ell_y^2 \right) 
</md></p></li>
  </ul>

  <subsection xml:id="subsec-213">
    <title>PHY 213</title>

    <ul>
      <li><p><md>
Q = N e
</md></p></li>
<li><p><md>
\vec{F} = \frac{1}{4\pi \epsilon_0} \frac{ \lvert q_1 q_2 \rvert}{r^2} \hat{r}
= k \frac{ \lvert q_1 q_2 \rvert}{r^2}\hat{r}
</md></p></li>
<li><p><md>
\vec{E} = \frac{\vec{F}}{q}
 = k \frac{q}{r^2} \hat{r}
</md></p></li>
<li><p><md>
\vec{E}= k \int \frac{\mathrm{d} q}{r^2} \hat{r}
</md></p></li>
<li><p><md>
\vec \tau = \vec p \times \vec E
~;~
 \vec p  = q \vec d
</md></p></li>
<li><p><md>
U = - \vec p \cdot \vec E
</md></p></li>
<li><p><md>
\mathrm{PE} = U = k \frac{q_1 q_2}{r} 
</md></p></li>
<li><p><md>
V = \frac{U}{q} = -\frac{\mathrm{W}}{q}
</md></p></li>
<li><p><md>
V_\mathrm{a} - V_\mathrm{b} 
   = \int_{\mathrm{a}}^{\mathrm{b}} 
    \vec{E} \cdot \mathrm{d} \vec{\ell}
</md></p></li>
<li><p><md>
V = k \frac{q}{r} =k \sum \frac{q_i}{r_i}
</md></p></li>
<li><p><md>
\vec{E} = - \left( 
  \hat{\imath} \frac{\partial V}
               {\partial x} +
  \hat{\jmath} \frac{\partial V}
               {\partial y} +
  \hat{k} \frac{\partial V}
               {\partial z} 
  \right)
</md></p></li>
<li><p><md>
\Phi_{E} = \oint \vec{E} \cdot \mathrm{d} \vec{A}
= \frac{q_\textnormal{enclosed}}{\epsilon_0}
</md></p></li>
<li><p><md>
\Phi_{E} = \vec{E}\cdot \vec{A}  = A E \cos \theta
</md></p></li>
<li><p><md>
C = \frac{q}{V}
</md></p></li>
<li><p><md>
C_0 = \frac{ \epsilon_0 A}{d}
</md></p></li>
<li><p><md>
C = K C_0 = \frac{ K \epsilon_0 A}{d}
= \frac{ \epsilon A}{d}
</md></p></li>
<li><p><md>
\frac{1}{C_\mathrm{series}} = 
\frac{1}{C_1} + \frac{1}{C_2} + \ldots
</md></p></li>
<li><p><md>
C_\mathrm{parallel} = C_1 + C_2 + \ldots
</md></p></li>
<li><p><md>
U = \frac{1}{2} q V
 = \frac{1}{2} \frac{q^2}{C}
= \frac{1}{2} C V^2
</md></p></li>
<li><p><md>
u = \frac{\epsilon_0}{2} E^2
</md></p></li>
<li><p><md>
I = \frac{d q}{d t}
</md></p></li>
<li><p><md>
I = n q A v_\mathrm{drift}
</md></p></li>
<li><p><md>
\vec{J} = n q \vec v_\mathrm{drift}
</md></p></li>
<li><p><md>
V_{ab} = \mathcal{E} - I r
</md></p></li>
<li><p><md>
V = I R
</md></p></li>
<li><p><md>
R = \frac{\rho \ell}{A}
</md></p></li>
<li><p><md>
\rho = \rho_0 (1 + \alpha \Delta T)
</md></p></li>
<li><p><md>
R = R_0 (1 + \alpha \Delta T)
</md></p></li>
<li><p><md>
P = I V
= \frac{V^2}{R}
 = I^2 R
</md></p></li>
<li><p><md>
\sum I_i = 0
</md></p></li>
<li><p><md>
\sum V_i = 0
</md></p></li>
<li><p><md>
R_\mathrm{series} = R_1 + R_2 + \ldots
</md></p></li>
<li><p><md>
\frac{1}{R_\mathrm{parallel}} = 
\frac{1}{R_1} + 
\frac{1}{R_2} + \ldots
</md></p></li>
<li><p><md>
\tau = R C
</md></p></li>
<li><p><md>
q = C \mathcal{E} ( 1 - e^{-t/RC})
</md></p></li>
<li><p><md>
i = \frac{\mathcal{E}}{R} e^{-t/RC}
= I_0 e^{-t/RC}
</md></p></li>
<li><p><md>
q = Q_0 e^{-t/RC}
</md></p></li>
<li><p><md>
\vec{F}_B = q \vec{v} \times \vec{B}
</md></p></li> 
<li><p><md>
R= \frac{m v}{q B}
</md></p></li>
<li><p><md>
\vec{F} = I \vec{\ell} \times \vec{B} 
</md></p></li>
<li><p><md>
\vec{\mu} = N I \hat{A}
</md></p></li>
<li><p><md>
\vec{\tau} = \vec{\mu} \times \vec{B}
</md></p></li>
<li><p><md>
{\tau} = \mu {B} \sin \phi
</md></p></li>
<li><p><md>
U = -\vec{\mu} \cdot \vec{B}
=-\mu B \cos \phi
</md></p></li>
<li><p><md>
\Phi_{B} \equiv \oint \vec{B} \cdot \mathrm{d} \vec{A}
</md></p></li>
<li><p><md>
\Phi_{B} = \vec{B}\cdot \vec{A}  = A B \cos (\theta)
</md></p></li>
<li><p><md>
\vec{B} = \frac{\mu_0}{4 \pi} \frac{q \vec{v} \times \hat{r}}{r^2}
</md></p></li>
<li><p><md>
B = \frac{\mu_0 I}{2 \pi r}
</md></p></li>
<li><p><md>
B = \frac{N \mu_0 I}{2 r}
</md></p></li>
<li><p><md>
B = \frac{N \mu_0 I}{\ell} = n \mu_0 I
</md></p></li>
<li><p><md>
\frac{F}{\ell} = \frac{\mu_0 I_1 I_2 }{2 \pi r} 
</md></p></li>
<li><p><md>
\oint  \vec{B} \cdot \vec{dl} = \mu_0 I_{encl} 
</md></p></li>
<li><p><md>
\mathcal{E} = - \frac{d\Phi_\mathrm{tot}}{d t}
= - N \frac{d \Phi}{d t}
</md></p></li>
<li><p><md>
\oint  \vec{E} \cdot \vec{dl} = - \frac{d \Phi_B}{dt}
</md></p></li>
<li><p><md>
\mathcal{E} = v B L
</md></p></li>
<li><p><md>
\mathcal{E} =  N A B \omega \sin(\omega t)
</md></p></li>
<li><p><md>
M =\frac{N_2 \Phi_{B2}}{i_1} = \frac{N_1 \Phi_{B1}}{i_2}
</md></p></li>
<li><p><md>
L=\frac{N \Phi_B}{i}
</md></p></li>
<li><p><md>
\mathcal{E}=-L \frac{di}{dt}
</md></p></li>
<li><p><md>
U = L\int^I_0 idi=\frac{1}{2}L I^2
</md></p></li>
<li><p><md>
u = \frac{B^2}{2 \mu_0}
</md></p></li>
<li><p><md>
\tau = \frac{L}{R}
</md></p></li>
<li><p><md>
i = \frac{\mathcal{E}}{R}  ( 1 - e^{-t/\tau})
</md></p></li>
<li><p><md>
\omega = \frac{1}{\sqrt{L C}}
</md></p></li>
<li><p><md>
q = Q \cos (\omega t)
</md></p></li>
<li><p><md>
i = -\omega Q \sin (\omega t) 
</md></p></li>
<li><p><md>
\omega' ={\sqrt {\frac{1}{L C}-\frac{R^2}{4 L^2}}}
</md></p></li>
<li><p><md>
i =  I \cos (\omega t)
</md></p></li>
<li><p><md>
I_\mathrm{rms}=\frac{I}{\sqrt{2}}
~;~
V_\mathrm{rms}=\frac{V}{\sqrt{2}}
</md></p></li>
<li><p><md>
X_C = \frac{1}{2 \pi f C} = \frac{1}{\omega C}
</md></p></li>
<li><p><md>
X_L = 2 \pi f L = \omega L 
</md></p></li>
<li><p><md>
Z_\mathrm{total} = \sqrt{R^2 + (X_L - X_C)^2}
</md></p></li>
<li><p><md>
I_\mathrm{rms} = \frac{V_\mathrm{rms}}{Z}
</md></p></li>
<li><p><md>
  \tan \phi = \frac{V_L - V_C}{V_R}= \frac{X_L - X_C}{R}
</md></p></li>
<li><p><md>
P_\mathrm{av} =\frac{1}{2} V I \cos \phi
</md></p></li>
<li><p><md>
P_\mathrm{av}  = I_\mathrm{rms} V_\mathrm{rms} \cos \phi
</md></p></li>
<li><p><md>
\omega_\mathrm{res} = 2 \pi 
f_\mathrm{res} = \frac{1}{\sqrt{L C}}
</md></p></li>
<li><p><md>
\frac{V_\mathrm{S}}{V_\mathrm{P}} = \frac{N_\mathrm{S}}{N_\mathrm{P}} = \frac{I_\mathrm{P}}{I_\mathrm{S}}
</md></p></li>
<li><p><md>
E_\mathrm{max} = c B_\mathrm{max} 
</md></p></li>
<li><p><md>
c = \frac{1}{\sqrt{\mu_0 \epsilon_0}}
</md></p></li>
<li><p><md>
v = \frac{1}{\sqrt{\mu \epsilon}} = \frac{c}{\sqrt{K K_m}}
</md></p></li>
<li><p><md>
n = \frac{c}{v}=\frac{\lambda_0}{\lambda}
</md></p></li>
<li><p><md>
c = f \lambda
</md></p></li>
<li><p><md>
\vec{S} = \frac{1}{\mu_0} \vec{E} \times \vec{B}
</md></p></li>
<li><p><md>
I_\mathrm{av} =S_\mathrm{av} = \frac{E_\mathrm{max} B_\mathrm{max}}{2 \mu_0}
</md></p></li>
<li><p><md>
I = \frac{P_{source}}{A} = \frac{P_{source}}{4 \pi r^2}
</md></p></li>
<li><p><md>
p_\mathrm{rad, abs} =\frac{I}{c}
~;~
p_\mathrm{rad, ref} =\frac{2I}{c}
</md></p></li>
<li><p><md>
n_1 \sin(\theta_1) = n_2 \sin(\theta_2)
</md></p></li>
<li><p><md>
\lambda = \frac{\lambda_0}{n}
</md></p></li>
<li><p><md>
\theta_\mathrm{crit} = \sin^{-1} \left(\frac{n_2}{n_1}\right)
</md></p></li>
<li><p><md>
I=I_\mathrm{max} \cos^2(\phi) =\tfrac{1}{2} I_0 \cos^2(\phi)
</md></p></li>
<li><p><md>
\theta_\mathrm{pol} = \tan^{-1} \left(\frac{n_2}{n_1}\right)
</md></p></li>
<li><p><md>
m = \frac{h_\mathrm{im}}{h_\mathrm{ob}} = - \frac{s_\mathrm{im}}{s_\mathrm{ob}}
</md></p></li>
<li><p><md>
f = \frac{R}{2}
</md></p></li>
<li><p><md>
P = \frac{1}{f} = \frac{1}{s_\mathrm{ob}} +\frac{1}{s_\mathrm{im}}
</md></p></li>
<li><p><md>
\frac{1}{f} = \left( n-1 \right) \left( \frac{1}{R_1} - \frac{1}{R_2} \right)
</md></p></li>
<li><p><md>
m = m_\mathrm{objective} \; m_\mathrm{eyepiece} 
</md></p></li>
<li><p><md>
M = \frac{\theta'}{\theta} = \frac{25 cm}{f}
</md></p></li>
<li><p><md>
M = \frac{\theta_\mathrm{telescope}}{\theta_\textnormal{naked eye}} = - \frac{f_\mathrm{o}}{f_\mathrm{e}}
</md></p></li>
<li>
  <p>
    <md>
      <mrow>  \amp d  \sin(\theta)  = m \lambda ~~(\textnormal{max} ) </mrow>
      <mrow> \amp \textnormal{where } m \in \{ 0, \pm 1,  \pm 2, \ldots \}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \amp d \sin(\theta) =  \left(m + \frac{1}{2}\right) \lambda ~~(\textnormal{min} ) </mrow>
      <mrow> \amp \textnormal{where } m \in \{ 0, \pm 1,  \pm 2, \ldots \}</mrow>
    </md>
  </p>
</li>
<li><p><md>
y = R\frac{m \lambda}{d}
</md></p></li>
<li><p><md>
I=I_0  \cos^2({\phi}/{2})
</md></p></li>
<li><p><md>
\phi = \frac{2 \pi}{\lambda}(r_2 - r_1)
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \amp 2 t = m \lambda</mrow>
      <mrow> \amp \textnormal{where } m \in \{ 0,  1,  2, \ldots \}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \amp 2 t = \left(m + \frac{1}{2}\right) \lambda</mrow>
      <mrow> \amp \textnormal{where } m \in \{ 0, 1, 2, 3, \ldots \}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \amp a  \sin(\theta)  = m \lambda ~~(\textnormal{min})</mrow>
      <mrow> \amp \textnormal{where } m \in \{\pm 1,  \pm 2, \ldots \}</mrow>
    </md>
  </p>
</li>
<li><p><md>
I=I_0 \left [ \frac{\sin({\phi}/{2})}{\beta/2} \right ]^2
</md></p></li>
<li><p><md>
\beta= \frac{2 \pi}{\lambda} a  \sin(\theta)
</md></p></li>
<li><p><md>
\sin(\theta) = 1.22 \frac{\lambda}{D}
</md></p></li>
<li>
  <p>
    <md>
      <mrow> \amp 2d \sin (\theta) = m \lambda</mrow>
      <mrow> \amp \textnormal{where } m \in \{ 1, 2, 3, \ldots \}</mrow>
    </md>
  </p>
</li>
<li><p><md>
E_\mathrm{photon} = h f  = \frac{h c}{\lambda} = p c
</md></p></li>
<li><p><md>
K_\mathrm{max} = h f - \mathrm{\Phi}
</md></p></li>
<li><p><md>
\lambda' -\lambda = \frac{h}{m c}\left (1 - \cos(\phi) \right )
</md></p></li>
<li><p><md>
\Delta x \Delta p_x \geq \frac{\hbar}{2}
~;~
\Delta t \Delta E \geq \frac{\hbar}{2}
</md></p></li>
<li><p><md>
\lambda = \frac{h}{p} =\frac{h}{m v}
</md></p></li>
<li><p><md>
E_{n} = -\frac{h c R}{n^2}
~;~
R = \frac{m e^4}{8 \epsilon_0^2 h^3 c}
</md></p></li>
    </ul>
    
  </subsection>


  
</section>
