<?xml version="1.0" encoding="UTF-8"?>

<section xml:id="notes-week-01">
  <title>Marshall University Algebra-based Introductory Physics Formula Sheet for Common Final Exam</title>

  <subsection xml:id="subsec-PHY-201">
    <title>PHY 201</title>

    <ul>
      <li><p><md>
 \vec{v}  = \frac{\Delta \vec{r}} {\Delta t}
 </md></p></li>
<li><p><md>
x_\mathrm{f} = x_\mathrm{i} + v_\mathrm{i} t + \tfrac{1}{2} a t^2
</md></p></li>
<li><p><md>
v_\mathrm{f} =  v_\mathrm{i} + a t
</md></p></li>
<li><p><md>
v_\mathrm{f}^2 =  v_\mathrm{i}^2 + 
2 a (x_\mathrm{f} - x_\mathrm{i})
</md></p></li>
<li><p><md>
v_\mathrm{avg} =  \tfrac{1}{2} 
(v_\mathrm{f} + v_\mathrm{i}) 
</md></p></li>
<li><p><md>
  \Delta \vec{r}  = \vec{v}_\mathrm{avg} \Delta t
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{net} \equiv \sum_i \vec{F}_i
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{net} = m \vec{a}
</md></p></li>
<li><p><md>
F_g = w = m g
</md></p></li>
<li><p><md>
\lvert \vec{F}_\mathrm{s} \rvert \leq \mu_\mathrm{s} \lvert \vec{n} \rvert
</md></p></li>
<li><p><md>
\lvert \vec{F}_\mathrm{k} \rvert  = \mu_\mathrm{k} \lvert \vec{n} \rvert
</md></p></li>
<li><p><md>
\vec{F}_\mathrm{S} = - k \vec{x}
</md></p></li>
<li><p><md>
\omega = \frac{v_\mathrm{t}}{r}
</md></p></li>
<li><p><md>
a_\mathrm{c} =
\frac{v_\mathrm{t}^2}{r}
= r \omega^2
</md></p></li>
<li><p><md>
F_G = G \frac{m_1 m_2}{r^2}
</md></p></li>
<li><p><md>
g = G \frac{m_\mathrm{earth}}{r^2_\mathrm{earth}}
</md></p></li>
<li><p><md>
W = \vec{F}\cdot\vec{d} 
= \lvert \vec{F} \rvert \lvert \vec{d} \rvert \cos (\theta)
</md></p></li>
<li><p><md>
P_{av}=\frac{\Delta W}{\Delta t}
</md></p></li>
<li><p><md>
\mathrm{KE} = K \equiv \tfrac{1}{2} m v^2
</md></p></li>
<li><p><md>
W_\mathrm{net} = \Delta K
</md></p></li>
<li><p><md>
W_\mathrm{cons} = -\Delta U = - \Delta \mathrm{PE}
</md></p></li>
<li><p><md>
\mathrm{PE}_g = U_g = m g h
</md></p></li>
<li><p><md>
U_G = - G \frac{m_1 m_2}{r}
</md></p></li>
<li><p><md>
\mathrm{PE}_\mathrm{S} = U_\mathrm{S} = \tfrac{1}{2} k x^2
</md></p></li>
<li><p><md>
\vec{r}_\mathrm{cm} \equiv \frac{\sum_i m_i \vec{r}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{v}_\mathrm{cm} \equiv \frac{\sum_i m_i \vec{v}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{a}_\mathrm{cm} \equiv \frac{\sum_i m_i \vec{a}_i}{\sum_i m_i}
</md></p></li>
<li><p><md>
\vec{p} \equiv m \vec{v}
</md></p></li>
<li><p><md>
\vec{F} = \frac{\Delta \vec{p}}{\Delta t}
</md></p></li>
<li><p><md>
\vec{p}_{1,\mathrm{f}} + \vec{p}_{2,\mathrm{f}} = 
\vec{p}_{1,\mathrm{i}} + \vec{p}_{2,\mathrm{i}}\; .
</md></p></li>
<li><p><md>
\vec{\mathcal{J}} \equiv \vec{F} \Delta t = \Delta \vec{p} 
</md></p></li>
%<li><p><md>
%\vec{\tau} \equiv \vec{r} \times \vec{F}
%</md></p></li>
<li><p><md>
\tau = r F \sin \theta
</md></p></li>
<li><p><md>
r_\perp = r \sin (\theta) 
</md></p></li>
<li><p><md>
\sum\tau = r_\perp F = I \alpha
</md></p></li>
%<li><p><md>
%\ell_\mathrm{in} F_\mathrm{in} = 
%\ell_\mathrm{out} F_\mathrm{out}
%</md></p></li>
<li><p><md>
  \theta =\frac{s}{r}
</md></p></li>
<li><p><md>
 \omega = \frac{\Delta \theta}{\Delta t} = \frac{v_\mathrm{t}}{r} 
</md></p></li>
<li><p><md>
 \alpha = \frac{\Delta \omega}{\Delta t} = \frac{a_\mathrm{t}}{r} 
</md></p></li>
<li><p><md>
  v = r \omega % \sin \theta
</md></p></li>

<li><p><md>
\theta_\mathrm{f} = \theta_\mathrm{i} + \omega_\mathrm{i} t + \tfrac{1}{2} \alpha t^2</md></p></li> 
<li><p><md>
\omega_\mathrm{f} =  \omega_\mathrm{i} + \alpha t </md></p></li> 
<li><p><md>
\omega_\mathrm{f}^2 =  \omega_\mathrm{i}^2 + 
2 \alpha (\theta_\mathrm{f} - \theta_\mathrm{i}) </md></p></li> 

<li><p><md>
\omega_\mathrm{avg} =  \tfrac{1}{2} 
(\omega_\mathrm{f} + \omega_\mathrm{i}) 
</md></p></li>
<li><p><md>
L = r p \sin \theta = I \omega
</md></p></li>
<li><p><md>
L = r (m v) \sin \theta
</md></p></li>
<li><p><md>
\vec{\tau} = \frac{\Delta \vec{L}}{\Delta t}
</md></p></li>
<li><p><md>
  W = \tau \Delta \theta 
</md></p></li>
<li><p><md>
  K_\mathrm{rot} = \tfrac{1}{2} I \omega^2
</md></p></li>
<li><p><md>
 \omega = 2 \pi f = \frac{2 \pi}{T}
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{k}{m} }
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{g}{\ell} }
</md></p></li>
<li><p><md>
 \omega = \sqrt{ \frac{m g \ell_\mathrm{cm}}{I} }
</md></p></li>
<li><p><md>
  T = 2 \pi \sqrt{ \frac{L}{g}}
</md></p></li>
<li><p><md>
  T = 2 \pi \sqrt{ \frac{I}{m g \ell_\mathrm{cm}}}
</md></p></li>
<li><p><md>
 x(t) = x_\mathrm{max} \cos (\omega t)
</md></p></li>
<li><p><md>
 v(t) = -\omega x_\mathrm{max} \sin (\omega t)
</md></p></li>
<li><p><md>
 a(t) = - \omega^2 x_\mathrm{max} \cos (\omega t)
</md></p></li>
<li><p><md>
  E = \tfrac{1}{2} k x_\mathrm{max}^2
</md></p></li>
<li><p><md>
 v = f \lambda 
</md></p></li>
<li><p><md>
  \mu \equiv \frac{m}{\ell}
</md></p></li>
<li><p><md>
  v = \sqrt{ \frac{F}{\mu} }
</md></p></li>
<li><p><md>
  k \equiv \frac{2 \pi}{\lambda}
</md></p></li>
<li><p><md>
 y_\mathrm{sw} (x,t) = \bigl [ A \sin (k x)\bigr ] \sin(\omega t)  
</md></p></li>
<li><p><md>
 f_\mathrm{string} = f_\mathrm{open-open} 
  = n \left( \frac{v}{2 \ell} \right) 
 \hspace{0.3cm}
\textnormal{where } n \in \{  1,  2, 3, \ldots \} 
</md></p></li>
<li><p><md>
 \ell = n \frac{\lambda_n}{2} 
 \hspace{0.3cm}
\textnormal{where } n \in \{  1,  2, 3, \ldots \} 
</md></p></li>
<li><p><md>
 f_\mathrm{open-closed}   = 
   n \left( \frac{v}{4 \ell} \right) 
 \hspace{0.3cm}
\textnormal{where } n \in \{  1,  3, 5, \ldots \} 
</md></p></li>
<li><p><md>
 \ell = n \frac{\lambda_n}{4}  \hspace{0.3cm}
\textnormal{where } n \in \{  1,  3, 5, \ldots \} 
</md></p></li>
<li><p><md>
 y_\mathrm{tw} (x,t) = A \sin (k x \mp \omega t)
</md></p></li>
<li><p><md>
 f_\mathrm{o} = f_\mathrm{s} 
   \left( \frac{v \pm v_\mathrm{o}}{v \mp v_\mathrm{s}} \right) 
</md></p></li>
<li><p><md>
 \Delta{L} = m\lambda 
</md></p></li>
<li><p><md>
 \Delta{L} = (m - \frac{1}{2} )\lambda 
</md></p></li>
<li><p><md>
 f_\mathrm{beat} = \lvert f_2 - f_1 \rvert 
</md></p></li>
<li><p><md>
 P = \frac{F}{A}
</md></p></li>
<li><p><md>
  \rho = \frac{m}{V}
</md></p></li>
<li><p><md>
 F_\mathrm{b} = \rho V g 
</md></p></li>
<li><p><md>
 P = P_0 + \rho g h 
</md></p></li>
<li><p><md>
 P + \rho g y + \tfrac{1}{2} \rho v^2 = \mathrm{const}
</md></p></li>
<li><p><md>
Q  = \Phi_v \equiv \vec{v}\cdot \vec{A}  = v A \cos (\theta)
</md></p></li>
<li><p><md>
Q = \frac{\Delta V}{\Delta t}
</md></p></li>
<li><p><md>
  A_1 v_1 = A_2 v_2
</md></p></li>
<li><p><md>
 \rho v A  = \frac{\Delta m}{\Delta t}
</md></p></li>
    </ul>
    
  </subsection>
  
  <subsection xml:id="subsec-Moments-of-Inertia">
    <title>Moments of Inertia</title>
    <p>
      <ul>
        <li><p><md>
\textnormal{hoop about axis} \hspace{0.3cm} I = m r^2
</md></p></li>
<li><p><md>
\textnormal{point particle about axis at distance } r \hspace{0.3cm}  I = m r^2 
</md></p></li>
<li><p><md>
\textnormal{ring about axis} \hspace{0.3cm} I =  \frac{1}{2} m 
\left( r_1^2 + r_2^2 \right) 
</md></p></li>
<li><p><md>
\textnormal{solid disk about axis} \hspace{0.3cm} I =  \frac{1}{2} m r^2
</md></p></li>
<li><p><md>
\textnormal{solid disk about diameter} \hspace{0.3cm}  
I =  \frac{1}{4} m r^2 + \frac{1}{12} m \ell^2
</md></p></li>
<li><p><md>
\textnormal{thin rod, axis through center}
\perp \textnormal{to length} \hspace{0.3cm}  
I =  \frac{1}{12} m \ell^2 
</md></p></li>
<li><p><md>
\textnormal{thin rod, axis through end}
\perp \textnormal{to length} \hspace{0.3cm}  
I =  \frac{1}{3} m \ell^2 
</md></p></li>
<li><p><md>
\textnormal{solid sphere about diameter}
\hspace{0.3cm}  
I =  \frac{2}{5} m r^2 
</md></p></li>
<li><p><md>
\textnormal{thin spherical shell about diameter}
\hspace{0.3cm} 
I =  \frac{2}{3} m r^2 
</md></p></li>
<li><p><md>
\textnormal{hoop about any diameter}
\hspace{0.3cm}  
I =  \frac{1}{2} m r^2 
</md></p></li>
<li><p><md>
\textnormal{slab about} \perp 
\textnormal{axis through center}
\hspace{0.3cm}  
I =  \frac{1}{2} m \left( \ell_x^2 + \ell_y^2 \right) 
</md></p></li>
      </ul>
    </p>
  </subsection>

  <subsection xml:id="subsec-Page-2">
    <title>Page 2</title>

    <ul>
      <li><p><md>
 \textrm{circumference of a circle ; } C =  2 \pi r
</md></p></li>
<li><p><md>
 \textrm{area of a circle ; } A =  \pi r^2
</md></p></li>
<li><p><md>
 \textrm{surface area of a sphere ; } A =  4 \pi r^2
</md></p></li>
<li><p><md>
 \textrm{volume of a sphere ; } V =  \frac{4}{3} \pi r^3
</md></p></li>
<li><p><md>
\textrm{If } A x^2 + B x + C = 0 \textrm{,  } 
x = \frac{{-B \pm \sqrt{B^2 - 4 A C }}}{2 A}
</md></p></li>
<li><p><md>
 \log_a (xy) =  \log_a (x) +  \log_a (y)
</md></p></li>
<li><p><md>
 \log_a \left(\frac{x}{y}\right) =  \log_a (x) -  \log_a (y)
</md></p></li>
<li><p><md>
 \log_a \left(x^y\right) =  y\log_a (x)
</md></p></li>
<li><p><md>
\mathrm{If \;}  a^x = y
\mathrm{, \;}
 x = \log_a y = \frac{\log_{10} y}{\log_{10} a}
 = \frac{\ln y}{\ln a}
</md></p></li>
<li><p><md>
\mathrm{If \;} \lvert \theta \rvert &lt; 0.5 
\mathrm{\; radians, \;}
 \sin (\theta) \approx \theta
 \mathrm{\; (in \; radians) \;}
</md></p></li>
<li><p><md>
\mathrm{If \;} \lvert \theta \rvert &lt; 0.5 
\mathrm{\; radians, \;}
 \tan (\theta) \approx \theta
 \mathrm{\; (in \; radians) \;}
</md></p></li>
<li><p><md>
 \sin (-\theta) = - \sin (\theta)
</md></p></li>
<li><p><md>
 \cos (-\theta) =  \cos (\theta)
</md></p></li>
<li><p><md>
\sin(\theta_A + \theta_B) = \sin(\theta_A) \cos(\theta_B) + \cos(\theta_A) \sin(\theta_B)
</md></p></li>
<li><p><md>
\cos(\theta_A + \theta_B) = \cos(\theta_A) \cos(\theta_B) - \sin(\theta_A) \sin(\theta_B)
</md></p></li>
<li><p><md>
\sin(\theta_A) \sin(\theta_B) = 
\frac{\cos(\theta_A - \theta_B) - 
 \cos(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
\cos(\theta_A) \cos(\theta_B) = 
\frac{\cos(\theta_A - \theta_B) + 
 \cos(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
\sin(\theta_A) \cos(\theta_B) = 
\frac{\sin(\theta_A - \theta_B) + 
 \sin(\theta_A + \theta_B)}{2}
</md></p></li>
<li><p><md>
 \textnormal{Law of Cosines}  \hspace{0.5cm}
 c^2 = a^2 + b^2 - 2 a b \cos (C)
</md></p></li>
<li><p><md>
 \textnormal{Law of Sines}  \hspace{0.5cm}
 \frac{a}{\sin (A)} =  \frac{b}{\sin (B)} =  \frac{c}{\sin (C)} 
</md></p></li>
<li><p><md>
  \left.
  \begin{array}{rcl}
  x \amp = \amp r \cos (\theta) \\
  y \amp = \amp r \sin (\theta)
  \end{array}
  \right\}
  \Longleftrightarrow
  \left\{
  \begin{array}{rcl}
  r \amp = \amp \sqrt{x^2 + y^2} \\
  \theta \amp = \amp \tan^{-1} \left( y/x \right)
  + \left\{
  \begin{array}{l}
      0^{\circ} \mathrm{, \; if \; } x &lt; 0 \\
      180^{\circ} \mathrm{, \; otherwise }
   \end{array}
   \right .
  \end{array}
  \right.
</md></p></li>

<li><p><md>
\mathrm{If \; } \vec{R} =  \vec {A} + \vec{B} , \;
R_x =  A_x + B_x \; \mathrm{and} \; 
R_y =  A_y + B_y
</md></p></li>
<li><p><md>
\mathrm{If \; } \vec{R} =  \vec {A} - \vec{B} , \;
R_x =  A_x - B_x \; \mathrm{and} \; 
R_y =  A_y - B_y
</md></p></li>
<li><p><md>
 \vec{A}\cdot\vec{B} =  \vec{B}\cdot\vec{A}  =  A_x  B_x + A_y B_y + A_z B_z  =  \lvert \vec{A} \rvert \lvert \vec{B} \rvert \cos(\theta)
</md></p></li>
<li><p><md>
 \lvert \vec{A} \times \vec{B} \rvert = \lvert \vec{A} \rvert \lvert \vec{B} \rvert \lvert \sin(\theta) \rvert
</md></p></li>
<li><p><md>
\textnormal{Newton's constant}  \hspace{0.5cm}
G = 6.67430 \! \times \!  10^{-11} \; 
\frac{\mathrm{m}^3}{\mathrm{kg}\cdot \mathrm{s}^2} 
</md></p></li>
<li><p><md>
\textrm{speed of light  }  
 c \equiv 2.99792458 \times 10^8 \textnormal{ m/s}
</md></p></li>
<li><p><md>
\textnormal{elementary charge  }  
 e = 1.602176634 \!\times\! 10^{-19} \textnormal{ C}
</md></p></li>
<li><p><md>
\mathrm{electrostatic \; constant \;}
k = 8.987551792 \!\times\! 10^9 
\frac{\mathrm{\; N}\cdot \mathrm{m}^2}{\mathrm{C}^2} 
</md></p></li>
<li><p><md>
\mathrm{vacuum}\; \mathrm{permittivity \; }
 \epsilon_0 = 8.854187813 \!\times\! 10^{-12} \mathrm{\; F/m}
</md></p></li>
<li>
  <p>
    vacuum permeability
    <md>
      <mrow> \mu_0 \amp = 1.2566370621\!\times\! 10^{-6} 
 \mathrm{\; N} \cdot \mathrm{A}^{-2} </mrow>
 <mrow> \amp \approx
 4 \pi \!\times\! 10^{-7} 
 \mathrm{\; N} \cdot \mathrm{A}^{-2} </mrow>
    </md>
  </p>
</li>

<li><p><md>
\textnormal{Planck's constant} \;
 h = 6.62607015 \!\times\! 10^{-34}  
 \mathrm{\; J} \cdot \mathrm{s}
</md></p></li>
<li><p><md>
\hbar \equiv \frac{h}{2 \pi} = 1.054571817 \!\times\! 10^{-34}  
 \mathrm{\; J} \cdot \mathrm{s}
</md></p></li>
<li><p><md>
\textnormal{standard gravity} \hspace{0.5 cm}
g = +9.80665 \; \frac{\mathrm{m}}{\mathrm{s}^2}
</md></p></li>
<li><p><md>
\textnormal{mass of  earth} \hspace{0.5 cm} m_\mathrm{earth} = 5.9723 \!\times\! 10^{24} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of moon} \hspace{0.5 cm} m_\mathrm{moon} = 7.346 \!\times\! 10^{22} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of sun} \hspace{0.5 cm} m_\mathrm{sun} = 1.9885 \!\times\! 10^{30} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of electron} \hspace{0.3 cm} m_\mathrm{e} = 9.1093837015 \!\times\! 10^{-31} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of proton} \hspace{0.3 cm} m_\mathrm{p} = 
1.67262192369 \!\times\! 10^{-27} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{mass of neutron} \hspace{0.3 cm} m_\mathrm{n} = 1.67492749804  \!\times\! 10^{-27} \; \mathrm{kg}
</md></p></li>
<li><p><md>
\textnormal{volumetric radius of earth} \hspace{0.3 cm} r_\mathrm{earth} = 
6.371 \!\times\! 10^{6} \; \mathrm{m}
</md></p></li>
<li><p><md>
\textnormal{earth-moon distance} \hspace{0.3 cm} r_\mathrm{EM} = 
3.844 \!\times\! 10^{8} \; \mathrm{m}
</md></p></li>
<li><p><md>
\textnormal{earth-sun distance} \hspace{0.3 cm} r_\mathrm{ES} = 
1.496 \!\times\! 10^{11} \; \mathrm{m}
</md></p></li>
<li>
  <p>
    Density of air at sea level at 15<m>^\circ</m> C:
    <md>
      \rho_0 = 1.225 \frac{\mathrm{kg}}{\mathrm{m}^3}
    </md>
    
  </p>
</li>
<li>
  <p>
    Earth's total magnetic field strength at Huntington, WV:
    <md>
      \lvert \vec{B}_\mathrm{earth} \rvert \approx
5.15 \!\times\! 10^{-5} \; \mathrm{T}
    </md>
    
  </p>
</li>
<li>
  <p>
    Vertical component of Earth's magnetic field strength at Huntington, WV:
    <md>
      B_{\mathrm{earth},z} \approx
4.70 \!\times\! 10^{-5} \; \mathrm{T}
    </md>
    
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \textnormal{Bohr radius} \hspace{0.5cm} a_B \amp \equiv 
\frac{\hbar^2}{m_\mathrm{e} k e^2} </mrow>
<mrow> \amp = 5.29177210903 \!\times\! 10^{-11} \; \mathrm{m}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> \textnormal{Rydberg constant} \hspace{0.3cm} \amp \equiv 
\frac{\hbar}{4 \pi m_\mathrm{e} a_B^2 c}</mrow>
<mrow> \amp = 1.0973731568160  \times 10^7 \; \mathrm{m}^{-1}</mrow>
    </md>
  </p>
</li>

<li><p><md>
\textnormal{hydrogen binding energy} \hspace{0.3cm} 
E_0 
= 13.605693123 \; \mathrm{eV}
</md></p></li>
<li><p><md>
\textnormal{scale for nuclear radius} 
\hspace{0.3cm} 
 r_\mathrm{nuc} = 1.2 \!\times\! 10^{-11} \; \mathrm{m}
</md></p></li>
    </ul>
    
  </subsection>

  <subsection xml:id="subsec-Page-3">
    <title>Page 3</title>

    <ul>
      <li><p><md>
1 \; \mathrm{newton \;  [N]} \equiv 1 \;
\frac{\mathrm{kilogram} \cdot \mathrm{meter}}{ \mathrm{second}^2}
</md></p></li>
<li><p><md>
1 \; \mathrm{joule \; [J]} \equiv 1 \; \mathrm{newton} \cdot \mathrm{meter}
</md></p></li>
<li><p><md>
1 \; \mathrm{watt \; [W]} = 
1 \; \frac{\mathrm{joule}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{radian} \equiv \frac{180^\circ}{\pi} 
\approx 57.29577951^\circ
</md></p></li>

<li>
  <p>
    <md>
      <mrow> 1 \; \frac{\mathrm{radian}}{\mathrm{second}} \amp \equiv \frac{60}{2 \pi} \; \mathrm{rpm} </mrow>
      <mrow> \amp \approx 9.549296586 \; \mathrm{rpm} </mrow>
    </md>
  </p>
</li>

<li><p><md>
1 \; \mathrm{hertz \; [Hz]} \equiv 1 \; \mathrm{second}^{-1}
</md></p></li>
<li><p><md>
1 \; \mathrm{pascal \; [Pa]} \equiv 1 \; 
\frac{\mathrm{newton}}{\mathrm{meter}^2}
</md></p></li>
<li><p><md>
1 \; \mathrm{volt \; [V]} \equiv 
1 \; \frac{\mathrm{joule}}{\mathrm{coulomb}}
</md></p></li>
<li><p><md>
1 \; \mathrm{electron-volt \; [eV]} = 
1.602176565 \!\times\! 10^{-19} \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \mathrm{farad \; [F]} \equiv 
1 \; \frac{\mathrm{coulomb}}{\mathrm{volt}}
</md></p></li>
<li><p><md>
1 \; \mathrm{ampere \; [A]} \equiv
1 \; \frac{\mathrm{coulomb}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{ohm} \; [\Omega] \equiv
1 \; \frac{\mathrm{volt}}{\mathrm{ampere}}
</md></p></li>
<li><p><md>
1 \; \mathrm{tesla} \equiv 
1 \; \frac{\mathrm{newton}}{\mathrm{ampere}\cdot
\mathrm{meter}}
</md></p></li>
<li><p><md>
1 \; \mathrm{gauss \; [G]} \equiv 10^{-4} \; \mathrm{tesla}
</md></p></li>
<li><p><md>
1 \; \mathrm{henry \; [H]} \equiv 
1 \; \mathrm{ohm} \cdot \mathrm{second}
</md></p></li>
<li><p><md>
1 \; \mathrm{diopter \; [D]} \equiv 1 \; \mathrm{meter}^{-1}
</md></p></li>
<li><p><md>
1 \; \mathrm{dalton \; [u]} = 
1.66053873 \!\times\! 10^{-27} \; \mathrm{kilogram}
</md></p></li>
<li><p><md>
1 \; \mathrm{becquerel \; [Bq]} \equiv 
1 \frac{\mathrm{decay}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{curie \; [Ci]} \equiv
3.7 \! \times \! 10^{10} \; \mathrm{becquerel}
</md></p></li>
<li><p><md>
 1 \; \mathrm{rad} \equiv 
 0.01 \; \frac{\mathrm{joule}}{\mathrm{kilogram}}
</md></p></li>
<li><p><md>
1 \; \mathrm{gray} \equiv 
 1 \; \frac{\mathrm{joule}}{\mathrm{kilogram}}
 = 100 \; \mathrm{rad}
</md></p></li>
<li><p><md>
1 \; \mathrm{rem} \equiv   
1 \; \mathrm{rad} \cdot RBE
</md></p></li>
<li><p><md>
1 \; \mathrm{sievert \; [Sv]} \equiv   
1 \; \mathrm{gray} \cdot RBE = 
100 \; \mathrm{rem}
</md></p></li>
<li><p><md>
1 \; \mathrm{inch \; [in]} \equiv   
0.0254 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{foot \; [ft]} =   
0.3048 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{mile \; [mi]} = 
1609.344 \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{light \; year \; [ly]} = 
9.4605284 \!\times\! 10^{15} \; \mathrm{meter} 
</md></p></li>
<li><p><md>
1 \; \mathrm{ounce mass \; [oz]} =   
0.02835 \; \mathrm{kilogram} 
</md></p></li>
<li><p><md>
1 \; \mathrm{pound mass \; [lb]} =
0.4536 \; \mathrm{kilogram} 
</md></p></li>
<li><p><md>
1 \; \mathrm{mile \; per \; hour \; [mph]} =
0.44704 \; \frac{\mathrm{meter}}{\mathrm{second}}
</md></p></li>
<li><p><md>
1 \; \mathrm{foot \; pound \; [ft \! \cdot \! lb]} =
1.3558179 \; \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \textnormal{centipoise [cP]}  \equiv 0.1 \;
\textnormal{pascal} \cdot \textnormal{second}
</md></p></li>
<li><p><md>
1 \; \mathrm{kiloton \; [kt]} =
4.184 \!\times\! 10^{12} \; \mathrm{joule}
</md></p></li>
<li><p><md>
1 \; \mathrm{horsepower \; [hp]} =
745.69987 \; \mathrm{watt}
</md></p></li>
<li><p><md>
1 \; \mathrm{atmosphere \; [atm]} = 
1.0132501 \!\times\! 10^{5} \; \mathrm{pascal}
</md></p></li>
<li><p><md>
1 \; \mathrm{mm \; of \; mercury \; [mmHg]} =
133.32239 \; \mathrm{pascal}
</md></p></li>
<li><p><md>
1 \; \mathrm{pound \; per \; square \; inch \; [psi]} =
6894.75728 \; \mathrm{pascal}
</md></p></li>
    </ul>

    
<table>
  <title>Prefixes</title>
  <tabular>
    <row>
      <cell><p>giga [G]: <m>10^{9}</m></p></cell>
      <cell><p>centi [c]: <m>10^{-2}</m></p></cell>
      <cell><p>nano [n]: <m>10^{-9}</m></p></cell>
    </row>
    <row>
      <cell><p>mega [M]: <m>10^{6}</m></p></cell>
      <cell><p>milli [m]: <m>10^{-3}</m></p></cell>
      <cell><p>pico [p]: <m>10^{-12}</m></p></cell>
    </row>
    <row>
      <cell><p>kilo [k]: <m>10^{3}</m></p></cell>
      <cell><p>micro [<m>\mu</m>]: <m>10^{-6}</m></p></cell>
      <cell><p>femto [f]: <m>10^{-15}</m></p></cell>
    </row>
  </tabular>
</table>

    
  </subsection>

<subsection xml:id="subsec-PHY-203">
  <title>PHY 203</title>

<ul>
  <li><p><md>
q = N e
</md></p></li>
<li><p><md>
  F = k \frac{\lvert q_1 q_2 \rvert}{r^2}
</md></p></li>
<li><p><md>
\vec{E} \equiv \frac{\vec{F}}{q}
</md></p></li>
<li><p><md>
  E = k \frac{\lvert q \rvert}{r^2}
</md></p></li>
<li><p><md>
\mathrm{PE} = U = k \frac{q_1 q_2}{r} 
</md></p></li>
<li><p><md>
\mathrm{V} \equiv \frac{U}{q} = \frac{-\mathrm{W}}{q}
</md></p></li>
<li><p><md>
\mathrm{V} = k \frac{q}{r} 
</md></p></li>
<li><p><md>
E_x = - \frac{\Delta \mathrm{V}(x)}{\Delta x}
</md></p></li>
<li><p><md>
\Phi_{E} = \vec{E}\cdot \vec{A}  = A \lvert \vec{E} \rvert \cos \theta
</md></p></li>
<li><p><md>
\Phi_E = \frac{q_\textnormal{enclosed}}{\epsilon_0}
</md></p></li>
<li><p><md>
C \equiv \frac{q}{\mathrm{V}}
</md></p></li>
<li><p><md>
C = \frac{\kappa \epsilon_0 A}{d}
</md></p></li>
<li><p><md>
\frac{1}{C_\mathrm{series}} = 
\frac{1}{C_1} + \frac{1}{C_2} + \ldots
</md></p></li>
<li><p><md>
C_\mathrm{parallel} = C_1 + C_2 + \ldots
</md></p></li>
<li><p><md>
U_{E} = \tfrac{1}{2} q \mathrm{V}
 = \tfrac{1}{2} \frac{q^2}{C}
= \tfrac{1}{2} C \mathrm{V}^2
</md></p></li>
<li><p><md>
u_{E} = \tfrac{1}{2} \epsilon_0 \lvert \vec{E} \rvert^2
</md></p></li>
<li><p><md>
I = \frac{\Delta q}{\Delta t}
</md></p></li>
<li><p><md>
\vec{I} = n q A \vec{v}_\mathrm{drift}
</md></p></li>
<li><p><md>
\mathrm{V} = I R
</md></p></li>
<li><p><md>
R = \frac{\rho \ell}{A}
</md></p></li>
<li><p><md>
\rho = \rho_0 (1 + \alpha \Delta T)
</md></p></li>
<li><p><md>
R = R_0 (1 + \alpha \Delta T)
</md></p></li>
<li><p><md>
P = I \mathrm{V}
 = \frac{\mathrm{V}^2}{R}
 = I^2 R
</md></p></li>
<li><p><md>
R_\mathrm{series} = R_1 + R_2 + \ldots
</md></p></li>
<li><p><md>
\frac{1}{R_\mathrm{parallel}} = 
\frac{1}{R_1} + 
\frac{1}{R_2} + \ldots
</md></p></li>
<li><p><md>
  Q_\mathrm{max} = {\cal E} C
</md></p></li>
<li><p><md>
\tau_{C} = R C
</md></p></li>
<li><p><md>
I(t) = I_\mathrm{max} e^{-t/\tau}
</md></p></li>
<li><p><md>
  \mathrm{V}_C = \mathrm{V}_\mathrm{battery} \left ( 1 - e^{-t/\tau} \right )
</md></p></li>
<li><p><md>
  I(t) = - I_\mathrm{max} e^{-t/\tau}
  </md></p></li>
<li><p><md>
\mathrm{V}_C = \mathrm{V}_\mathrm{battery}  e^{-t/\tau} 
</md></p></li>
<li><p><md>
F_B = q v_{\perp} B = q v B \sin \theta
</md></p></li> 
<li><p><md>
R = \frac{m v_{\perp}}{q B}
</md></p></li>
<li><p><md>
F = I \ell B \sin \theta 
</md></p></li>
<li><p><md>
\mu = N I A 
</md></p></li>
<li><p><md>
\tau = \mu B \sin \theta 
</md></p></li>
<li><p><md>
U = -\mu B \cos \theta 
</md></p></li>
<li><p><md>
B_{wire} = \frac{\mu_0 I}{2 \pi r}
</md></p></li>
<li><p><md>
B_{loop} = \frac{N \mu_0 I}{2 r}
</md></p></li>
<li><p><md>
B_{solenoid} = \frac{N \mu_0 I}{\ell} = n \mu_0 I
</md></p></li>
<li><p><md>
\frac{F}{\ell} = \frac{\mu_0 I_1 I_2 }{2 \pi r} 
</md></p></li>
<li><p><md>
{\cal E} = v_{\perp} B {\ell}  = v B {\ell} \sin \theta
</md></p></li>
<li><p><md>
\Phi_B \equiv \vec{B}\cdot \vec{A}  = B A \cos \theta
</md></p></li>
<li><p><md>
{\cal E} = - \frac{\Delta \Phi_\textrm{tot}}{\Delta t} = - N \frac{\Delta \Phi_1}{\Delta t}
</md></p></li>
<li><p><md>
{\cal E} =  N A B \omega \sin(\omega t)
</md></p></li>
<li><p><md>
{\cal E}  = - L \frac{\Delta I}{\Delta t}
</md></p></li>
<li><p><md>
  L = \mu_0 \left (\frac{N^2}{\ell} \right ) A
</md></p></li>
<li><p><md>
U_{B} = \frac{1}{2} L I^2
</md></p></li>
<li><p><md>
u_{B} = \frac{1}{2 \mu_0} B^2
</md></p></li>
<li><p><md>
\tau_{L} = \frac{L}{R}
</md></p></li>
<li><p><md>
  I(t) = \frac{V_\mathrm{baterry}}{R} \left(1 - e^{-t/\tau} \right )
</md></p></li>
<li><p><md>
\lvert \vec{E} \rvert = c \lvert \vec{B} \rvert 
</md></p></li>
<li><p><md>
c = \frac{1}{\sqrt{\mu_0 \epsilon_0}}
</md></p></li>
<li><p><md>
v = f \lambda
</md></p></li>
<li><p><md>
I = \frac{P_{source}}{A} = \frac{P_{source}}{4 \pi r^2}
</md></p></li>
<li><p><md>
I =  \tfrac{1}{2} c\epsilon_0 E_0^2 = \tfrac{1}{2} \frac{c}{\mu_0} B_0^2
</md></p></li>
<li><p><md>
I_p = \tfrac{1}{2} I_0 (\cos \theta)^2
</md></p></li>
<li><p><md>
E_{photon}=h f
</md></p></li>
<li><p><md>
\frac{Q}{\Delta t} = e \sigma A T^4
</md></p></li>
<li><p><md>
\lambda_{peak} = \frac{b}{T}
</md></p></li>
<li><p><md>
\mathrm{v}(t) = \mathrm{V}_0 \cos(\omega t)
</md></p></li>
<li><p><md>
I_{rms} = \frac{I_{peak}}{\sqrt{2}}
</md></p></li>
<li><p><md>
V_{rms} = \frac{V_{peak}}{\sqrt{2}}
</md></p></li>
<li><p><md>
X_C = \frac{1}{2 \pi f C} = \frac{1}{\omega C}
</md></p></li>
<li><p><md>
X_L = 2 \pi f L = \omega L 
</md></p></li>
<li><p><md>
I_\mathrm{rms} = \frac{\mathrm{V}_\mathrm{rms}}{\left \vert Z \right \vert}
</md></p></li>
<li><p><md>
Z = 
\sqrt{R^2 + (X_L - X_C)^2}
</md></p></li>
<li><p><md>
P_\mathrm{avg} = I_\mathrm{rms} \mathrm{V}_\mathrm{rms} \cos \phi
</md></p></li>
<li><p><md>
P_\mathrm{avg} = \tfrac{1}{2} I_{peak} \mathrm{V}_{peak}
=I_\mathrm{rms} \mathrm{V}_\mathrm{rms}
</md></p></li>
<li><p><md>
  \tan \phi = \frac{X_L - X_C}{R}
</md></p></li>
<li><p><md>
\omega_\mathrm{res} = 2 \pi 
f_\mathrm{res} = \frac{1}{\sqrt{L C}}
</md></p></li>
<li><p><md>
\frac{\mathrm{V}_\mathrm{S}}{\mathrm{V}_\mathrm{P}} = \frac{N_\mathrm{S}}{N_\mathrm{P}} = \frac{I_\mathrm{P}}{I_\mathrm{S}}
</md></p></li>
<li><p><md>
n \equiv \frac{c}{v}
</md></p></li>
<li><p><md>
n_1 \sin(\theta_1) = n_2 \sin(\theta_2)
</md></p></li>
<li><p><md>
\theta_c = \sin^{-1} \left(\frac{n_2}{n_1}\right)
</md></p></li>
<li><p><md>
P = \frac{1}{f} = \frac{1}{s} +\frac{1}{s^{\prime}}
</md></p></li>
<li><p><md>
\frac{1}{f} = \left( \frac{n_\mathrm{l} - n_\mathrm{m}}{n_\mathrm{m}} \right) \left( \frac{1}{R_1} - \frac{1}{R_2} \right)
</md></p></li>
<li><p><md>
m \equiv \frac{h^{\prime}}{h}
= - \frac{s^{\prime}}{s}
</md></p></li>
<li><p><md>
f = \frac{r}{2}
</md></p></li>
<li><p><md>
m = m_\mathrm{objective} \; m_\mathrm{eyepiece} 
</md></p></li>
<li><p><md>
m \sim \left( \frac{\mathrm{N.P.}}{f_\mathrm{e}} \right)
\left( \frac{\ell - f_\mathrm{e}}{d_\mathrm{o}} \right)
</md></p></li>
<li><p><md>
M = \frac{\theta_\mathrm{telescope}}{\theta_\textnormal{naked eye}} = - \frac{f_\mathrm{o}}{f_\mathrm{e}}
</md></p></li>
<li>
  <p>
    <md>
      <mrow> d \amp \sin(\theta)  = m \lambda </mrow>
      <mrow> \amp \textnormal{where } m \in \{ 0, \pm 1,  \pm 2, \ldots \}</mrow>
    </md>
  </p>
</li>
<li>
  <p>
    <md>
      <mrow> d \amp \sin(\theta) =  \left(m - \frac{1}{2}\right) \lambda </mrow>
      <mrow> \amp \textnormal{where } m \in \{  1,  2, \ldots \} </mrow>
    </md>
  </p>
</li>
<li><p><md>
y = L\frac{m \lambda}{d}
</md></p></li>
<li><p><md>
\sin(\theta) = 1.22 \frac{\lambda}{D}
</md></p></li>
<li><p><md>
E = \Delta m c^2
</md></p></li>
<li><p><md>
E_{photon} = h f = p c
</md></p></li>
<li><p><md>
E_{photon} = h f = \hbar \omega = \frac{h c}{\lambda}
</md></p></li>
<li><p><md>
\Delta r = 2 d \cos \theta_m = m \lambda;~ m = 1, 2, 3, ...
</md></p></li>
<li><p><md>
V_{stop}= \frac{K_{max}}{e}
</md></p></li>
<li><p><md>
\lambda = \frac{h}{p} = \frac{h}{mv}
</md></p></li>
<li><p><md>
r_n = \frac{n^2}{Z} a_\mathrm{B}
</md></p></li>
<li><p><md>
n \lambda_n = \frac{n h }{m_\mathrm{e} v_n} = 2 \pi r_n
</md></p></li>
<li><p><md>
E_n = -\frac{Z^2}{n^2} (13.6 \textnormal{ eV})
</md></p></li>
<li><p><md>
\frac{1}{\lambda} = \left(\frac{1}{n_\mathrm{f}^2}  
- \frac{1}{n_\mathrm{i}^2}\right) \mathcal{R}
</md></p></li>
<li><p><md>
Q = (M_A + M_B - M_C - M_D) c^2
</md></p></li>
<li><p><md>
\lvert \vec{L} \rvert = m_\mathrm{e} v r_n = n \frac {h}{2\pi}= n \hbar 
</md></p></li>
<li><p><md>
v_n = \frac{nh}{2 \pi m r_n} = \frac {2 \pi k e^2}{nh}
</md></p></li>
<li><p><md>
r_n = (\frac {h^2}{4 \pi^2 mkZe^2})n^2
</md></p></li>
<li><p><md>
N(t) = N_0 e^{-\lambda t} = N_0 2^{-t/t_{1/2}}
</md></p></li>
<li><p><md>
\lambda = \frac{\ln 2}{t_{1/2}}
</md></p></li>
<li><p><md>
R \equiv \frac{\Delta N}{\Delta t}
</md></p></li>
<li><p><md>
R = N \lambda = \frac{N \ln 2}{t_{1/2}}
</md></p></li>
<li><p><md>
  r = r_\mathrm{nuc} A^{1/3}
</md></p></li>
<li>
  <p>
    <term>Hydrogen Specturm Series</term>
    <md number="no">
      <mrow> \textnormal{Lymann: } \amp n_\mathrm{f} = 1 </mrow>
      <mrow> \textnormal{Balmer: } \amp n_\mathrm{f} = 2 </mrow>
      <mrow> \textnormal{Paschen: } \amp n_\mathrm{f} = 3 </mrow>
    </md>
  </p>
</li>
</ul>
  
</subsection>


</section>
